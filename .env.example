# Added automatically when the private content Blob store uses the CONTENT prefix.
CONTENT_BLOB_READ_WRITE_TOKEN=

# Added automatically when the public media Blob store uses the MEDIA prefix.
MEDIA_BLOB_READ_WRITE_TOKEN=

# Generate both secrets with: npm run auth:generate
ADMIN_PASSWORD_HASH=
AUTH_SECRET=

# Canonical public URL used by metadata and sitemap generation.
NEXT_PUBLIC_SITE_URL=
